generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum ListingCategory {
  STAYS
  CARS
  FOOD
  SALON
  BARBER
  SPA
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  role                 Role      @default(GUEST)
  passwordResetCode    String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Team Membership
  teamId               String?
  team                 Team?     @relation("TeamMembers", fields: [teamId], references: [id])

  // Teams Owned (a user can own one team)
  ownedTeams           Team[]    @relation("TeamOwner")

  // Listing Relation
  listings             Listing[]

  @@map("users")
}

model Team {
  id          String    @id // Generated with `tm_` prefix in service layer
  name        String
  description String?

  ownerId     String
  owner       User      @relation("TeamOwner", fields: [ownerId], references: [id])

  members     User[]    @relation("TeamMembers")
  listings    Listing[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("teams")
}

model Listing {
  id          String          @id @default(uuid())
  title       String
  description String
  category    ListingCategory
  price       Float
  location    String?
  images      String[]        @default([])
  isActive    Boolean         @default(true)

  // JSON field for dynamic category-specific attributes (e.g. carModel, bedrooms, cuisine)
  attributes  Json?

  hostId      String
  host        User            @relation(fields: [hostId], references: [id])

  teamId      String?
  team        Team?           @relation(fields: [teamId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("listings")
}
